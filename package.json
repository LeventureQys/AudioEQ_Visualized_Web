{
  "name": "audio-eq",
  "version": "2.0.0-alpha.0",
  "type": "module",
  "license": "MIT",
  "types": "./dist/types/index.d.ts",
  "main": "./dist/audio-eq.umd.js",
  "module": "./dist/audio-eq.es.js",
  "exports": {
    ".": {
      "import": "./dist/audio-eq.es.js",
      "require": "./dist/audio-eq.umd.js"
    }
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "happy-dom": "^20.10.3",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"examples/**/*.js\"",
    "typecheck": "tsc --noEmit",
    "types:emit": "tsc --emitDeclarationOnly"
  }
}
