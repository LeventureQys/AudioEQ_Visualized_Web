{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/types",
    "declaration": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*.js"]
}
